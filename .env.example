# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Neon PostgreSQL connection string
# Get this from: neon.tech -> your project -> Connection string
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"

# JWT secret - use a long random string (e.g. run: openssl rand -base64 48)
JWT_SECRET="replace-with-a-long-random-secret"

# JWT expiry (e.g. 7d, 24h, 30d)
JWT_EXPIRES_IN="7d"

# Registration invite code - share this with anyone you want to allow to register
REGISTRATION_CODE="replace-with-your-invite-code"

# API base URL (used in local dev)
VITE_API_URL="http://localhost:3001"
